<h1>{{supplier.name}}</h1>
<a class="btn btn-secondary mb-3" href="/">Back</a>

<form method="post" action="/supplier/{{supplier.id}}/frame" class="mb-4">
  <div class="row g-2">
    <div class="col-md-3">
      <input class="form-control" type="text" name="reference" placeholder="Reference" required>
    </div>
    <div class="col-md-3">
      <input class="form-control" type="number" step="1" min="0" name="quantity" placeholder="Quantity" required>
    </div>
    <div class="col-md-3">
      <input class="form-control" type="number" step="0.01" min="0" name="unit_price" placeholder="Unit Price" required>
    </div>
    <div class="col-md-3">
      <button class="btn btn-primary w-100" type="submit">Add Frame</button>
    </div>
  </div>
</form>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Reference</th>
      <th>Quantity</th>
      <th>Unit Price</th>
      <th>Total</th>
      <th>Sold</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {{#each frames}}
    <tr>
      <td>{{reference}}</td>
      <td>{{quantity}}</td>
      <td>{{unit_price}}</td>
      <td>{{multiply quantity unit_price}}</td>
      <td>{{sold}}</td>
      <td>
        <form method="post" action="/frame/{{id}}/sold" class="d-flex">
          <input type="number" name="sold" min="1" class="form-control me-2" placeholder="qty">
          <button class="btn btn-success">Add Sale</button>
        </form>
      </td>
    </tr>
    {{/each}}
  </tbody>
</table>
<div class="mt-3">
  <strong>Total Inventory Value: {{totalValue}}</strong>
</div>
<div>
  <strong>Total Sold Value: {{totalSold}}</strong>
</div>
